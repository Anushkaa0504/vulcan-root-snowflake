# Copy to .env: cp env.example .env  →  fill SNOWFLAKE_*  →  run: make up
# You can share this folder (Makefile + docker/*.yml + config + models) without the Vulcan monorepo;
# pull images from your registry (see Makefile VULCAN_IMAGE).
#
# Run the CLI via Docker (no pip). After `make network` + `make setup` (or `make up`):
#   make print-alias          # copy the line into ~/.zshrc / ~/.bashrc
#   vulcan -p . plan
# Or one-off:
#   make vulcan-cli CMD="plan"

# --- Snowflake (required) ---
SNOWFLAKE_ACCOUNT=EQZOTUQ-JCA67320
SNOWFLAKE_USER=kishan
SNOWFLAKE_PASSWORD=Tmdc@1234567890
SNOWFLAKE_WAREHOUSE=SNOWFLAKE_LEARNING_WH
SNOWFLAKE_DATABASE=DEMO_DB
SNOWFLAKE_ROLE=ACCOUNTADMIN
# Optional
# SNOWFLAKE_AUTHENTICATOR=snowflake

# --- State store (PostgreSQL from docker compose) ---
# Inside Docker (vulcan-api container): defaults statestore:5432 — leave unset.
# Vulcan CLI on your Mac/Linux host:
STATESTORE_HOST=statestore
STATESTORE_PORT=5432

# --- MinIO (from docker compose) ---
# Host CLI:
MINIO_ENDPOINT=http://minio:9000
# Inside Docker network (default in config.yaml):
# MINIO_ENDPOINT=http://minio:9000

# --- Vulcan state schema name in Postgres ---
STATE_SCHEMA=shreya

# --- Services (when running CLI on host; transpiler/GraphQL on localhost) ---
VULCAN_TRANSPILER_URL=http://vulcan-transpiler:4000
VULCAN_GRAPHQL_URL=http://vulcan-graphql:3000

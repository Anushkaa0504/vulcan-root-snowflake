# Copy to .env: cp env.example .env  →  fill SNOWFLAKE_*  →  run: make up
# You can share this folder (Makefile + docker/*.yml + config + models) without the Vulcan monorepo;
# pull images from your registry (see Makefile VULCAN_IMAGE).
#
# Run the CLI via Docker (no pip). After `make network` + `make setup` (or `make up`):
#   make print-alias          # copy the line into ~/.zshrc / ~/.bashrc
#   vulcan -p . plan
# Or one-off:
#   make vulcan-cli CMD="plan"

# --- Snowflake (required) ---
SNOWFLAKE_ACCOUNT=xy12345.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=YOUR_DB
SNOWFLAKE_ROLE=YOUR_ROLE

# Optional
# SNOWFLAKE_AUTHENTICATOR=snowflake

# --- State store (PostgreSQL from docker compose) ---
# Inside Docker (vulcan-api container): defaults statestore:5432 — leave unset.
# Vulcan CLI on your Mac/Linux host:
STATESTORE_HOST=localhost
STATESTORE_PORT=5431

# --- MinIO (match b2b_saas; default in config is http://minio:9000) ---
# Vulcan in Docker / make vulcan-cli: leave MINIO_ENDPOINT unset or use http://minio:9000
# vulcan on host (pip) with local ports:
MINIO_ENDPOINT=http://localhost:9000

# --- Vulcan state schema name in Postgres ---
STATE_SCHEMA=vulcan_try

# Transpiler + GraphQL URLs are fixed in config.yaml (b2b_saas: vulcan-transpiler-api:8100, vulcan-graphql:3000).
# If you run `vulcan` on the host (pip) instead of Docker, override:
#   export VULCAN__TRANSPILER__BASE_URL=http://127.0.0.1:8100
#   export VULCAN__GRAPHQL__BASE_URL=http://127.0.0.1:3000


alias vulcan="docker run -it --network=vulcan --rm -v .:/workspace tmdcio/vulcan-snowflake:0.228.1.12-rc2 vulcan"